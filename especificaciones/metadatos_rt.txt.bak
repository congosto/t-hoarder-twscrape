

## metadatos del autor del tweet
'user_id': str(tweet.user.id),
'user_displayname': tweet.user.displayname,
'followers_count': getattr(tweet.user'followersCount', 0) or 0,
'friends_count': getattr(tweet.user, 'friendsCount', 0) or 0,
'statuses_count': getattr(tweet.user, 'statusesCount', 0) or 0,
'favourites_count': getattr(tweet.user, 'favouritesCount', 0) or 0,
'listed_count': getattr(tweet.user.'listedCount', 0) or 0,
'location': getattr(tweet.user.'location', 0) or 0,
'create_at': getattr(tweet.user, 'create_at', 0) or 0
'user_verified': getattr(tweet.user, 'verified', False) or False
'is_blue_verified': getattr(tweet.user, 'blue', False) or False
'verified_type': getattr(tweet.user, 'blueType', False) or False


